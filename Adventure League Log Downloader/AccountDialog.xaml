<Window x:Class="Adventure_League_Log_Downloader.AccountDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Adventurers League account" Height="260" Width="440" MinWidth="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="16,14,16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0"
               Style="{StaticResource FormLabel}"
               Target="{Binding ElementName=UsernameTextBox}">
            <AccessText Text="_Username"/>
        </Label>
        <TextBox x:Name="UsernameTextBox"
                 Grid.Row="0" Grid.Column="1"
                 Margin="0,0,0,10"
                 TabIndex="0"
                 AutomationProperties.Name="Username"/>

        <Label Grid.Row="1" Grid.Column="0"
               Style="{StaticResource FormLabel}"
               Target="{Binding ElementName=PasswordBox}">
            <AccessText Text="_Password"/>
        </Label>
        <PasswordBox x:Name="PasswordBox"
                     Grid.Row="1" Grid.Column="1"
                     Margin="0,0,0,10"
                     TabIndex="1"
                     AutomationProperties.Name="Password"/>

        <CheckBox x:Name="RememberCredentialsCheckBox"
                  Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
                  Margin="0,0,0,8"
                  TabIndex="2"
                  Content="Re_member credentials in Windows Credential Manager"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                   TextWrapping="Wrap"
                   VerticalAlignment="Top"
                   Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}"
                   Text="Required to sign in to AdventurersLeagueLog.com. Your password is not stored in the app settings file."/>

        <StackPanel Grid.Row="4"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="0,14,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Margin="0,0,10,0"
                    TabIndex="3"
                    IsDefault="True"
                    Click="OnOkClick"
                    Content="_OK"/>
            <Button TabIndex="4"
                    IsCancel="True"
                    Content="_Cancel"/>
        </StackPanel>
    </Grid>
</Window>
