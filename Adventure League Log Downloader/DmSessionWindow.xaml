<Window x:Class="Adventure_League_Log_Downloader.DmSessionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="DM Session Downloader" Height="620" Width="960" MinWidth="700" MinHeight="460"
        WindowStartupLocation="CenterOwner">
    <DockPanel LastChildFill="True">
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem HorizontalAlignment="Left">
                <TextBlock x:Name="StatusText" Text="Ready"/>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="16,14,16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="SessionsSummary"
                       Grid.Row="0"
                       Margin="0,0,0,10"
                       TextWrapping="Wrap"
                       Text="DM sessions from the last download appear here. Download (no selection) uses the options below, then refreshes from the site. With rows selected, Download fetches detail for those sessions only (Ctrl/Shift-click)."/>

            <DataGrid x:Name="SessionsDataGrid"
                      Grid.Row="1"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      SelectionMode="Extended"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      TabIndex="0"
                      Sorting="SessionsDataGrid_OnSorting"
                      AutomationProperties.Name="DM sessions">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Date DMed"      Binding="{Binding DateDmed}"       Width="100"/>
                    <DataGridTextColumn Header="Adventure Title" Binding="{Binding AdventureTitle}" Width="3*" MinWidth="140"/>
                    <DataGridTextColumn Header="Session #"      Binding="{Binding SessionNum}"     Width="70"/>
                    <DataGridTextColumn Header="Reward"         Binding="{Binding DmRewardChoice}" Width="*"  MinWidth="80"/>
                    <DataGridTextColumn Header="Character"      Binding="{Binding CharacterName}"  Width="*"  MinWidth="100"/>
                    <DataGridCheckBoxColumn Header="Detail"
                                            Binding="{Binding DetailFetched}"
                                            SortMemberPath="DetailFetched"
                                            Width="52"/>
                </DataGrid.Columns>
            </DataGrid>

            <Grid Grid.Row="2" Margin="{StaticResource ActionBarMargin}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">
                    <CheckBox x:Name="SkipDmSessionDetailsCheckBox"
                              Margin="0,0,0,6"
                              TabIndex="1"
                              Content="List _only (refresh DM session list; skip detail pages)"
                              Checked="OnSkipDmSessionDetailsChanged"
                              Unchecked="OnSkipDmSessionDetailsChanged"/>
                    <CheckBox x:Name="OnlyMissingDmSessionDetailsCheckBox"
                              TabIndex="2"
                              Content="When fetching details, only download sessions still _missing detail"
                              Checked="OnOnlyMissingDmSessionDetailsChanged"
                              Unchecked="OnOnlyMissingDmSessionDetailsChanged"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="ClearSessionSelectionButton"
                            Margin="0,0,8,0"
                            TabIndex="3"
                            Click="OnClearSessionSelectionClick"
                            Content="Clear _selection"/>
                    <Button x:Name="DownloadButton"
                            TabIndex="4"
                            IsDefault="True"
                            Click="OnDownloadClick"
                            Content="_Download">
                        <Button.ToolTip>
                            <TextBlock TextWrapping="Wrap" MaxWidth="320"
                                       Text="No selection: refresh the DM list from the site; detail pages follow your checkboxes below. With rows selected: fetch full detail for each selected session (ignores list-only / missing-only for that run)."/>
                        </Button.ToolTip>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
