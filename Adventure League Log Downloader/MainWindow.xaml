<Window x:Class="Adventure_League_Log_Downloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Adventure_League_Log_Downloader"
        mc:Ignorable="d"
        Title="Adventurers League Log Downloader" Height="420" Width="720" MinWidth="640" MinHeight="360">
    <DockPanel LastChildFill="True">
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="_File">
                <MenuItem Header="E_xit" Click="OnExitClick"/>
            </MenuItem>
            <MenuItem Header="_Options">
                <MenuItem Header="Save _Defaults" Click="OnSaveDefaultsClick"/>
                <Separator/>
                <MenuItem Header="_Delay..." Click="OnDelayOptionsClick"/>
                <Separator/>
                <MenuItem Header="Open Settings _Folder" Click="OnOpenSettingsFolderClick"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="About" Click="OnAboutClick"/>
            </MenuItem>
        </Menu>

        <!-- StatusBar must NOT be the last child when LastChildFill=True; otherwise it fills the remaining space.
             Place it before the content Grid so it docks to the bottom correctly. -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem HorizontalAlignment="Left">
                <TextBlock x:Name="StatusText" Text="Ready"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Keep the main content Grid as the LAST child so it fills the remaining space -->
        <Grid Margin="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="160"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Username -->
            <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center">Username</TextBlock>
            <TextBox x:Name="UsernameTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,8,8" MinWidth="320"/>

            <!-- Password (not persisted) -->
            <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center">Password</TextBlock>
            <Grid Grid.Row="1" Grid.Column="1" Margin="0,0,8,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <PasswordBox x:Name="PasswordBox" Grid.Row="0" MinWidth="320"/>
                <CheckBox x:Name="RememberCredentialsCheckBox" Grid.Row="1" Margin="0,6,0,0" Content="Remember credentials"/>
            </Grid>

            <!-- Output folder with browse -->
            <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center">Output folder</TextBlock>
            <TextBox x:Name="OutputFolderTextBox" Grid.Row="2" Grid.Column="1" Margin="0,0,8,8" MinWidth="320"/>
            <Button x:Name="BrowseFolderButton" Grid.Row="2" Grid.Column="2" Margin="0,0,0,8" Padding="12,4" Click="OnBrowseFolderClick">Browse…</Button>

            <!-- Output file name -->
            <TextBlock Grid.Row="3" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center">Output file name</TextBlock>
            <TextBox x:Name="OutputFileTextBox" Grid.Row="3" Grid.Column="1" Margin="0,0,8,8" MinWidth="320"/>

            <!-- Buttons -->
            <StackPanel Grid.Row="5" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="RunButton" Margin="0,0,8,0" Padding="16,6" Click="OnRunClick">Run</Button>
                <Button x:Name="SaveDefaultsButton" Padding="16,6" Click="OnSaveDefaultsClick">Save Defaults</Button>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
