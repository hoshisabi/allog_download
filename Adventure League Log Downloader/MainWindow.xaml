<Window x:Class="Adventure_League_Log_Downloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Adventure_League_Log_Downloader"
        mc:Ignorable="d"
        Title="Adventurers League Log Downloader" Height="520" Width="820" MinWidth="700" MinHeight="400">
    <DockPanel LastChildFill="True">
        <Menu DockPanel.Dock="Top" KeyboardNavigation.TabNavigation="Cycle">
            <MenuItem Header="_File">
                <MenuItem Header="E_xit" Click="OnExitClick"/>
            </MenuItem>
            <MenuItem Header="_Options">
                <MenuItem Header="Save _Defaults" Click="OnSaveDefaultsClick"/>
                <Separator/>
                <MenuItem Header="_Account..." Click="OnAccountClick"/>
                <MenuItem Header="_Data location..." Click="OnDataLocationClick"/>
                <MenuItem Header="_Delay..." Click="OnDelayOptionsClick"/>
                <Separator/>
                <MenuItem Header="Open Settings _Folder" Click="OnOpenSettingsFolderClick"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="OnAboutClick"/>
            </MenuItem>
        </Menu>

        <!-- StatusBar must NOT be the last child when LastChildFill=True; otherwise it fills the remaining space.
             Place it before the content Grid so it docks to the bottom correctly. -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem HorizontalAlignment="Left">
                <TextBlock x:Name="StatusText" Text="Ready"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Keep the main content Grid as the LAST child so it fills the remaining space -->
        <Grid Margin="16,14,16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="LastWebsiteDownloadText"
                       Grid.Row="0"
                       Margin="0,0,0,10"
                       TextWrapping="Wrap"
                       Text="Last downloaded from site: never"/>

            <!-- Live character preview while scraping / from last saved file -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="140"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="CharactersPreviewSummary"
                           Grid.Row="0"
                           Margin="0,0,0,8"
                           TextWrapping="Wrap"
                           Text="Characters from your last download will appear here. Use Download to refresh from the site."/>
                <DataGrid x:Name="CharactersDataGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          SelectionMode="Single"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          TabIndex="0"
                          AutomationProperties.Name="Character preview">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" MinWidth="100"/>
                        <DataGridTextColumn Header="Class" Binding="{Binding Class}" Width="*" MinWidth="72"/>
                        <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="56"/>
                        <DataGridTextColumn Header="Race" Binding="{Binding Race}" Width="*" MinWidth="72"/>
                        <DataGridTextColumn Header="Season" Binding="{Binding Season}" Width="64"/>
                        <DataGridTextColumn Header="Tag" Binding="{Binding Tag}" Width="64"/>
                        <DataGridTextColumn Header="Last session" Binding="{Binding LastSessionPlayed}" Width="110" MinWidth="96"/>
                        <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <!-- Buttons: Download is default action from the form -->
            <StackPanel Grid.Row="2"
                        Margin="{StaticResource ActionBarMargin}"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="DownloadButton"
                        TabIndex="1"
                        IsDefault="True"
                        Click="OnDownloadClick"
                        Content="_Download"/>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>
