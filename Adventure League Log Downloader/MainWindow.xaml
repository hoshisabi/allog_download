<Window x:Class="Adventure_League_Log_Downloader.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Adventure_League_Log_Downloader"
        mc:Ignorable="d"
        Title="Adventurers League Log Downloader" Height="560" Width="860" MinWidth="720" MinHeight="420">
    <DockPanel LastChildFill="True">
        <Menu DockPanel.Dock="Top" KeyboardNavigation.TabNavigation="Cycle">
            <MenuItem Header="_File">
                <MenuItem Header="Export _session log workbook (CSV)…"
                          Click="OnExportSessionLogWorkbookClick"/>
                <Separator/>
                <MenuItem Header="E_xit" Click="OnExitClick"/>
            </MenuItem>
            <MenuItem Header="_Options">
                <MenuItem Header="Save _Defaults" Click="OnSaveDefaultsClick"/>
                <Separator/>
                <MenuItem Header="_Account..." Click="OnAccountClick"/>
                <MenuItem Header="_Data location..." Click="OnDataLocationClick"/>
                <MenuItem Header="_Delay..." Click="OnDelayOptionsClick"/>
                <Separator/>
                <MenuItem Header="Open _Files in Explorer" Click="OnOpenDataFilesInExplorerClick"/>
                <MenuItem Header="Open Settings _Folder" Click="OnOpenSettingsFolderClick"/>
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Header="_About" Click="OnAboutClick"/>
            </MenuItem>
        </Menu>

        <!-- StatusBar must NOT be the last child when LastChildFill=True; otherwise it fills the remaining space.
             Place it before the content Grid so it docks to the bottom correctly. -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem HorizontalAlignment="Left">
                <TextBlock x:Name="StatusText" Text="Ready"/>
            </StatusBarItem>
        </StatusBar>

        <!-- Keep the main content Grid as the LAST child so it fills the remaining space -->
        <Grid Margin="16,14,16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="LastWebsiteDownloadText"
                       Grid.Row="0"
                       Margin="0,0,0,10"
                       TextWrapping="Wrap"
                       Text="Last downloaded from site: never"/>

            <!-- Live character preview while scraping / from last saved file -->
            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="140"/>
                </Grid.RowDefinitions>
                <TextBlock x:Name="CharactersPreviewSummary"
                           Grid.Row="0"
                           Margin="0,0,0,8"
                           TextWrapping="Wrap"
                           Text="Characters from your last download appear here. Download refreshes the list from the site; with one or more rows selected, Download fetches CSVs for those characters (Ctrl/Shift-click)."/>
                <DataGrid x:Name="CharactersDataGrid"
                          Grid.Row="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeRows="False"
                          SelectionMode="Extended"
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          TabIndex="0"
                          Sorting="CharactersDataGrid_OnSorting"
                          AutomationProperties.Name="Character preview">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" MinWidth="100"/>
                        <DataGridTextColumn Header="Class" Binding="{Binding Class}" Width="*" MinWidth="72"/>
                        <DataGridTextColumn Header="Level" Binding="{Binding Level}" Width="56"/>
                        <DataGridTextColumn Header="Race" Binding="{Binding Race}" Width="*" MinWidth="72"/>
                        <DataGridTextColumn Header="Season" Binding="{Binding Season}" Width="64"/>
                        <DataGridTextColumn Header="Tag" Binding="{Binding Tag}" Width="64"/>
                        <DataGridCheckBoxColumn Header="CSV"
                                                Binding="{Binding HasLocalCsv}"
                                                IsReadOnly="True"
                                                Width="48"/>
                        <DataGridTextColumn Header="Last session" Binding="{Binding LastSessionPlayed}" Width="110" MinWidth="96"/>
                        <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="80"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>

            <Grid Grid.Row="2" Margin="{StaticResource ActionBarMargin}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center"
                            Margin="0,0,12,0">
                    <CheckBox x:Name="SkipCharacterCsvsCheckBox"
                              Margin="0,0,0,6"
                              TabIndex="1"
                              Content="List _only (refresh character list; skip CSV downloads)"
                              Checked="OnSkipCharacterCsvsChanged"
                              Unchecked="OnSkipCharacterCsvsChanged"/>
                    <CheckBox x:Name="OnlyMissingCharacterCsvsCheckBox"
                              TabIndex="2"
                              Content="When downloading CSVs, only fetch when the file is _missing"/>
                </StackPanel>
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="OpenAdditionalDataButton"
                            Margin="0,0,8,0"
                            TabIndex="3"
                            Click="OnAdditionalDataWindowClick"
                            Content="_More data…"/>
                    <Button x:Name="OpenDmSessionsButton"
                            Margin="0,0,8,0"
                            TabIndex="4"
                            Click="OnDmSessionWindowClick"
                            Content="_DM Sessions…"/>
                    <Button x:Name="ClearCharacterSelectionButton"
                            Margin="0,0,8,0"
                            TabIndex="5"
                            Click="OnClearCharacterSelectionClick"
                            Content="Clear _selection"/>
                    <Button x:Name="DownloadButton"
                            TabIndex="6"
                            IsDefault="True"
                            Click="OnDownloadClick"
                            Content="_Download">
                        <Button.ToolTip>
                            <TextBlock TextWrapping="Wrap" MaxWidth="280"
                                       Text="No selection: download character list from the site (and CSVs per your options). With rows selected: download CSV only for the selected characters."/>
                        </Button.ToolTip>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
