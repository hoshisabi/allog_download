<Window x:Class="Adventure_League_Log_Downloader.OptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Network delay" Height="168" Width="380" MinWidth="340"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="16,14,16,12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" MinWidth="140"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Label Grid.Row="0" Grid.Column="0"
               Style="{StaticResource FormLabel}"
               Target="{Binding ElementName=DelayTextBox}">
            <AccessText Text="Delay (_seconds)"/>
        </Label>
        <TextBox x:Name="DelayTextBox"
                 Grid.Row="0" Grid.Column="1"
                 Margin="0,0,0,10"
                 MinWidth="140"
                 HorizontalAlignment="Left"
                 TabIndex="0"
                 AutomationProperties.Name="Delay in seconds"/>

        <StackPanel Grid.Row="2"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Margin="0,14,0,0"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button Margin="0,0,10,0"
                    TabIndex="1"
                    IsDefault="True"
                    Click="OnOkClick"
                    Content="_OK"/>
            <Button TabIndex="2"
                    IsCancel="True"
                    Content="_Cancel"/>
        </StackPanel>
    </Grid>
</Window>
