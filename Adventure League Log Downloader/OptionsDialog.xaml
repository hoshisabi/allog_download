<Window x:Class="Adventure_League_Log_Downloader.OptionsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Options" Height="160" Width="360" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" ShowInTaskbar="False">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="160"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,8,8" VerticalAlignment="Center">Delay (seconds)</TextBlock>
        <TextBox x:Name="DelayTextBox" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" MinWidth="120"/>

        <StackPanel Grid.Row="2" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Margin="0,0,8,0" Padding="16,6" IsDefault="True" Click="OnOkClick">OK</Button>
            <Button Padding="16,6" IsCancel="True">Cancel</Button>
        </StackPanel>
    </Grid>
</Window>
